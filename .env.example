# Supabase project URL — powers the browser client and server auth + the office_files DB.
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon (public) key — used by the in-browser Supabase client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase service-role key — server-only secret; only used by the scripts/ DB tooling.
SUPABASE_SERVICE_ROLE_KEY=

# Base path the app is mounted under in prod; also prefixes the file API + asset URLs.
NEXT_PUBLIC_BASE_PATH=/office
# Autosave debounce in ms — how long after the last edit before content is saved.
NEXT_PUBLIC_DEBOUNCE_TIME=1000

# Where middleware redirects unauthenticated users (the suite login lives elsewhere).
NEXT_PUBLIC_LOGIN_URL=/login
# Shared cookie domain so the suite session is readable here (prod only), e.g. .geiger.studio
NEXT_PUBLIC_COOKIE_DOMAIN=

# Shared Geiger Studio Supabase project (same project across the suite).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Autosave debounce (ms) and client fetch base path (matches assetPrefix in prod).
NEXT_PUBLIC_DEBOUNCE_TIME=1000
NEXT_PUBLIC_BASE_PATH=/office

# Where to send unauthenticated users (the suite login lives on geiger-dash).
NEXT_PUBLIC_LOGIN_URL=/login
# Shared cookie domain so the dash session is readable here (production only),
# e.g. .geiger.studio
NEXT_PUBLIC_COOKIE_DOMAIN=

ASSETS_URL=
NOTES_URL=
RESEND_API_KEY=
